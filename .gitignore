# ============================================================
# Smart Hasaad — Repo-wide .gitignore
# ============================================================

# ---- Secrets / env files (NEVER commit) ----
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
develop-eggs/
dist/
build/
eggs/
parts/
sdist/
wheels/
.venv/
venv/
env/
ENV/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ---- Django ----
*.log
local_settings.py
backend/db.sqlite3
backend/db.sqlite3-journal
backend/staticfiles/
backend/media/
!backend/media/.gitkeep

# ---- Node / Next.js ----
node_modules/
.next/
out/
.vercel/
.turbo/
.swc/
*.tsbuildinfo
frontend/next-env.d.ts

# ---- Certificates (local HTTPS dev) ----
frontend/certificates/
*.pem
*.key
*.crt

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.DS_Store
Thumbs.db

# ---- OS ----
desktop.ini

# ---- Docker volumes ----
postgres_data/
redis_data/

# ---- Misc ----
*.bak
*.tmp
.cache/
