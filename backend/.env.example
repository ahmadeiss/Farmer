# ============================================================
# Smart Hasaad Backend — sample env.  Copy to backend/.env
# ============================================================

# ---- Django ----
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ---- Database ----
# Local dev (SQLite, zero-config):
DATABASE_URL=sqlite:///db.sqlite3
# Or PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/hasaad

# ---- Redis / Celery (optional in dev) ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- JWT ----
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- CORS / CSRF ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- QR delivery link (points to frontend /orders/confirm/<token>) ----
QR_CODE_BASE_URL=http://localhost:3000/orders/confirm

# ---- Production-only ----
# SECURE_SSL_REDIRECT=True

# ---- App scaffolds ----
OTP_PROVIDER=mock
TRANSCRIPTION_SERVICE=stub
ANALYTICS_CACHE_TIMEOUT_SECONDS=300
