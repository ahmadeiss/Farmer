# ============================================================
# Smart Hasaad Frontend — sample env.  Copy to frontend/.env.local
# ============================================================

# Public backend base URL (must be reachable from the browser).
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production on Vercel -> set to your Render backend URL, e.g.
# NEXT_PUBLIC_API_URL=https://hasaad-backend.onrender.com

NEXT_PUBLIC_APP_NAME=حصاد الذكي
